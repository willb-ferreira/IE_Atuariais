# Valor crítico da aproximação assintótica Qui-quadrado (nu = 2 parâmetros livres - 1 restrito sob H_0 = 1 g.l.)
qui_critico <- qchisq(1 - alpha, df = 1)
erro_tipo_I_TRVG <- mean(TRVG_estatistica > qui_critico)
cat("3. TRVG (GLRT) | H0: mu =", mu_0_teste, " vs H1: mu !=", mu_0_teste, "(variância desconhecida)\n")
cat("   Estatística W = -2ln(Lambda) com aproximação Qui-quadrado (1 g.l.)\n")
